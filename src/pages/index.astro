---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .slice(0, 3);
---

<Layout title="Sanjay Chaudhari — Software Engineer">

  <!-- Hero -->
  <section class="pb-14 border-b border-[var(--color-border)]">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0 shadow-lg shadow-blue-500/20">
        SC
      </div>
      <div>
        <p class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-0.5">Software Engineer</p>
        <h1 class="text-xl font-semibold text-[var(--color-text)] leading-tight">Sanjay Chaudhari</h1>
      </div>
    </div>

    <p class="text-[var(--color-muted-2)] text-base leading-relaxed max-w-xl mb-2">
      Building scalable backend systems and cloud-native applications with <span class="text-[var(--color-text)]">.NET & AWS</span>.
      Passionate about distributed systems, API design, and developer tooling.
    </p>
    <p class="text-[var(--color-muted)] text-sm mb-8">Based in India · Open to remote opportunities</p>

    <div class="flex gap-3">
      <a href="/about" class="px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors shadow-md shadow-blue-500/20">
        About Me
      </a>
      <a href="/blog" class="px-4 py-2 border border-[var(--color-border)] text-[var(--color-muted-2)] rounded-lg text-sm font-medium hover:border-[var(--color-border-hover)] hover:text-[var(--color-text)] transition-colors">
        Read Blog
      </a>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="py-12 border-b border-[var(--color-border)]">
    <div class="flex items-center justify-between mb-7">
      <h2 class="text-sm font-semibold text-[var(--color-text)] uppercase tracking-widest">Latest Posts</h2>
      <a href="/blog" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors">View all →</a>
    </div>
    <div class="space-y-px">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group flex items-start justify-between gap-6 py-4 border-b border-[var(--color-border)] last:border-0 hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-lg transition-colors">
          <div class="min-w-0">
            <h3 class="text-[var(--color-text)] text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors mb-1 truncate">
              {post.data.title}
            </h3>
            <p class="text-xs text-[var(--color-muted)] line-clamp-1">{post.data.description}</p>
          </div>
          <time class="text-xs text-[var(--color-muted)] whitespace-nowrap flex-shrink-0 mt-0.5" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section class="pt-12">
    <div class="flex items-center justify-between mb-7">
      <h2 class="text-sm font-semibold text-[var(--color-text)] uppercase tracking-widest">Featured Projects</h2>
      <a href="/projects" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors">View all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {projects.map((p) => (
        <a
          href={p.data.github ?? p.data.demo ?? '/projects'}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-2)] transition-all"
        >
          <h3 class="text-[var(--color-text)] text-sm font-semibold mb-1.5 group-hover:text-[var(--color-accent)] transition-colors">{p.data.name}</h3>
          <p class="text-xs text-[var(--color-muted)] leading-relaxed mb-3 line-clamp-2">{p.data.description}</p>
          <div class="flex flex-wrap gap-1">
            {p.data.tags.slice(0, 3).map((tag) => (
              <span class="text-[10px] px-1.5 py-0.5 bg-[var(--color-accent-dim)] text-[var(--color-accent)] rounded font-medium">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>
