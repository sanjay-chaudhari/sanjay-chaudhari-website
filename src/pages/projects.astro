---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const statusStyle: Record<string, string> = {
  Active: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
  Beta: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
  Stable: 'text-blue-400 bg-blue-400/10 border-blue-400/20',
};
---

<Layout title="Projects — Sanjay Chaudhari" description="Open-source projects and side projects built with .NET, AWS, and cloud-native technologies.">
  <div class="mb-10">
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-2">Projects</h1>
    <p class="text-[var(--color-muted)] text-sm">Things I've built and open-sourced.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {projects.map((p) => (
      <div class="group p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-2)] transition-all">
        <div class="flex items-start justify-between mb-3">
          <h2 class="text-[var(--color-text)] font-semibold text-sm group-hover:text-[var(--color-accent)] transition-colors">
            {p.data.name}
          </h2>
          <span class={`text-[10px] px-2 py-0.5 border rounded-full font-medium ${statusStyle[p.data.status]}`}>
            {p.data.status}
          </span>
        </div>
        <p class="text-xs text-[var(--color-muted)] leading-relaxed mb-4">{p.data.description}</p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          {p.data.tags.map((tag) => (
            <span class="text-[10px] px-1.5 py-0.5 bg-[var(--color-accent-dim)] text-[var(--color-accent)] rounded font-medium">
              {tag}
            </span>
          ))}
        </div>
        <div class="flex gap-4 pt-3 border-t border-[var(--color-border)]">
          {p.data.github && (
            <a href={p.data.github} target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors flex items-center gap-1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {p.data.demo && p.data.demo !== '#' && (
            <a href={p.data.demo} target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">
              Live Demo →
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</Layout>
