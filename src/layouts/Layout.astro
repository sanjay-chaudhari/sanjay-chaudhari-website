---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const {
  title,
  description = 'Sanjay Chaudhari — Software Engineer, .NET & Cloud specialist',
  image = '/og-default.svg',
  type = 'website',
  publishedDate,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
const ogImage = new URL(image, Astro.site);

const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImage,
      author: { '@type': 'Person', name: 'Sanjay Chaudhari', url: Astro.site },
      datePublished: publishedDate?.toISOString(),
      url: canonicalURL,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Sanjay Chaudhari',
      url: Astro.site,
      jobTitle: 'Software Engineer',
      sameAs: [
        'https://github.com/sanjay-chaudhari',
        'https://www.linkedin.com/in/sanjay-chaudhari-it/',
      ],
    };

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    </script>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sanjay Chaudhari" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Sanjay Chaudhari" />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col">

    <nav class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-[var(--color-text)] tracking-tight hover:text-[var(--color-accent)] transition-colors">
          sanjaychaudhari<span class="text-[var(--color-accent)]">.</span>com
        </a>
        <div class="flex items-center gap-1">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class={`px-3 py-1.5 rounded-md text-sm transition-colors ${
                  isActive
                    ? 'text-[var(--color-accent)] bg-[var(--color-accent-dim)]'
                    : 'text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]'
                }`}
              >
                {label}
              </a>
            );
          })}
          <button
            id="theme-toggle"
            aria-label="Toggle theme"
            class="ml-2 p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer"
          >
            <span id="theme-icon" class="text-base leading-none">☀️</span>
          </button>
        </div>
      </div>
    </nav>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-14">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between text-sm text-[var(--color-muted)]">
        <div>
          <span>© {new Date().getFullYear()} Sanjay Chaudhari</span>
          <p class="text-xs mt-1 opacity-60">Views and opinions expressed here are my own and do not represent my employer.</p>
        </div>
        <div class="flex gap-5">
          <a href="https://github.com/sanjay-chaudhari" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text)] transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/sanjay-chaudhari-it/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text)] transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const root = document.documentElement;
      function updateIcon() {
        document.getElementById('theme-icon').textContent =
          root.classList.contains('light') ? '🌙' : '☀️';
      }
      updateIcon();
      document.getElementById('theme-toggle').addEventListener('click', () => {
        root.classList.toggle('light');
        localStorage.setItem('theme', root.classList.contains('light') ? 'light' : 'dark');
        updateIcon();
      });
    </script>
  </body>
</html>
